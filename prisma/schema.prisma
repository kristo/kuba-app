// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

// ─── Auth ────────────────────────────────────────────────────────────────────

model User {
  id            String   @id @default(cuid())
  name          String
  email         String   @unique
  passwordHash  String
  isAdmin       Boolean  @default(false)
  createdAt     DateTime @default(now())

  predictions   Prediction[]
  ownedGroups   Group[]           @relation("OwnedGroups")
  groupMembers  GroupMembership[]
}

model InviteCode {
  id        String   @id @default(cuid())
  code      String   @unique
  usedBy    String?
  usedAt    DateTime?
  createdAt DateTime @default(now())
}

// ─── Tournament ───────────────────────────────────────────────────────────────

model Team {
  id          String  @id @default(cuid())
  name        String
  code        String  @unique   // e.g. "POL", "BRA"
  group       String?           // "A"–"L" (12 groups)
  flagEmoji   String?

  homeMatches Match[] @relation("HomeTeam")
  awayMatches Match[] @relation("AwayTeam")
}

enum MatchStage {
  GROUP
  ROUND_OF_32
  ROUND_OF_16
  QUARTER_FINAL
  SEMI_FINAL
  THIRD_PLACE
  FINAL
}

enum MatchStatus {
  UPCOMING
  LIVE
  FINISHED
}

model Match {
  id          String      @id @default(cuid())
  homeTeamId  String?
  awayTeamId  String?
  homeTeam    Team?       @relation("HomeTeam", fields: [homeTeamId], references: [id])
  awayTeam    Team?       @relation("AwayTeam", fields: [awayTeamId], references: [id])
  kickoff     DateTime
  stage       MatchStage
  groupLabel  String?     // "Group A", "Group B" …
  matchNumber Int         @unique
  venue       String?
  homeScore   Int?
  awayScore   Int?
  status      MatchStatus @default(UPCOMING)

  predictions Prediction[]
}

// ─── Predictions ─────────────────────────────────────────────────────────────

model Prediction {
  id          String   @id @default(cuid())
  userId      String
  matchId     String
  homeScore   Int
  awayScore   Int
  points      Int?     // null until match finished
  submittedAt DateTime @default(now())

  user  User  @relation(fields: [userId], references: [id])
  match Match @relation(fields: [matchId], references: [id])

  @@unique([userId, matchId])
}

// ─── Groups (private leagues) ─────────────────────────────────────────────────

model Group {
  id          String   @id @default(cuid())
  name        String
  inviteCode  String   @unique
  ownerId     String
  createdAt   DateTime @default(now())

  owner    User              @relation("OwnedGroups", fields: [ownerId], references: [id])
  members  GroupMembership[]
}

model GroupMembership {
  userId   String
  groupId  String
  joinedAt DateTime @default(now())

  user   User  @relation(fields: [userId], references: [id])
  group  Group @relation(fields: [groupId], references: [id])

  @@id([userId, groupId])
}
